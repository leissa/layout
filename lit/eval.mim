// RUN: %mim %s -o - | %FileCheck %s

plugin core;
plugin layout;

// Semantics of a plain row-major layout: index 7 of a 3×4 matrix is (1, 3) ↦ 1·4 + 3 = 7@mem.
// CHECK-DAG: lam extern rm7 (): %layout.Coord =
// CHECK-DAG: %layout.coord 1 (7, %layout.axis.mem);
lam extern rm7 (): %layout.Coord =
    %layout.eval (%layout.row_major (3, 4, %layout.axis.mem), 7_12);

// A sharded, offset, replicated layout: 4 lanes of 2 registers, based at lane 8, replicated
// over 2 warps. Index 5 = (lane 2, reg 1); the replicas enumerate warp 0 and warp 1.
// CHECK-DAG: lam extern distr (): «2; %layout.Coord» =
// CHECK-DAG: (%layout.coord 2 ((1, %layout.axis.reg), (10, %layout.axis.lane)), %layout.coord 3 ((1, %layout.axis.reg), (10, %layout.axis.lane), (1, %layout.axis.warp)));
lam extern distr (): «2; %layout.Coord» =
    %layout.eval (%layout.lt @(2, 1, 1) (((4, 1, %layout.axis.lane), (2, 1, %layout.axis.reg)),
                                         (2, 1, %layout.axis.warp),
                                         (8, %layout.axis.lane)),
                  5_8);

// Pure broadcast: the single element lives at the origin of every lane.
// CHECK-DAG: lam extern bc (): «2; %layout.Coord» =
// CHECK-DAG: (%layout.coord 0 (), %layout.coord 1 (1, %layout.axis.lane));
lam extern bc (): «2; %layout.Coord» =
    %layout.eval (%layout.bcast (2, %layout.axis.lane), 0_1);

// A symbolic index leaves eval stuck.
// CHECK-DAG: lam extern sym (x_{{[0-9]+}}: Idx 12): %layout.Coord =
// CHECK-DAG: %layout.eval (12, 1) (%layout.lt (1, 0, 0) ((12, 1, %layout.axis.mem), (), ()), x_{{[0-9]+}});
lam extern sym (x: Idx 12): %layout.Coord =
    %layout.eval (%layout.row_major (3, 4, %layout.axis.mem), x);
